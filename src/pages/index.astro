---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="Welcome to Isaac Newton University Lodge No. 859, Cambridge.">

  <section class="hero">
    <div class="hero-inner">
      <img src="/inul-crest.jpg" alt="Isaac Newton University Lodge Crest" class="hero-crest" />
      <div class="hero-symbol-wrap">
        <img src="/square-compasses.svg" alt="Square and Compasses" class="hero-symbol" />
      </div>
      <h1 class="hero-title">Isaac Newton University Lodge</h1>
      <p class="hero-subtitle">of Ancient, Free and Accepted Masons</p>
      <p class="hero-number">No. 859</p>
      <p class="hero-location">Cambridge</p>
    </div>
  </section>

  <section class="welcome">
    <div class="welcome-inner">
      <h2>Welcome</h2>
      <p>
        Isaac Newton University Lodge No. 859 is a University Lodge meeting in Cambridge,
        founded under the auspices of the United Grand Lodge of England. We meet three times
        a year during the University's academic terms, bringing together Freemasons connected
        to the University of Cambridge.
      </p>
      <div class="welcome-links">
        <a href="/history" class="btn">Our History</a>
        <a href="/meetings" class="btn btn-outline">Meeting Dates</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    background-color: #8EE8D8;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(26,39,68,0.08) 0%, transparent 50%);
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .hero-crest {
    width: min(220px, 45vw);
    height: auto;
    border-radius: 4px;
    box-shadow: 0 8px 32px rgba(26,39,68,0.2);
    margin-bottom: 0.5rem;
  }

  .hero-symbol-wrap {
    width: 64px;
    height: 70px;
    color: var(--navy);
  }

  .hero-symbol { width: 100%; height: 100%; }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4.5vw, 3rem);
    color: var(--navy);
    letter-spacing: 0.04em;
    line-height: 1.2;
    max-width: 700px;
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(0.95rem, 2.5vw, 1.3rem);
    color: var(--navy);
    opacity: 0.85;
    letter-spacing: 0.06em;
  }

  .hero-number {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--navy);
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .hero-location {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--navy);
    opacity: 0.7;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .welcome {
    background: var(--white);
    border-top: 4px solid var(--gold);
  }

  .welcome-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .welcome-inner h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--navy);
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .welcome-inner p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .welcome-links { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--navy);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover { background: var(--gold); border-color: var(--gold); color: var(--navy); }

  .btn-outline { background: transparent; color: var(--navy); }
  .btn-outline:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
</style>
