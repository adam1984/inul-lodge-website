---
import BaseLayout from '../layouts/BaseLayout.astro';

const terms = [
  {
    name: "Michaelmas Term",
    color: "#8EE8D8",
    meetings: [
      { label: "Installation Meeting", rule: "Last Tuesday in October", note: "The annual Installation of the Worshipful Master." },
      { label: "Regular Meeting", rule: "First Saturday in December" },
    ]
  },
  {
    name: "Lent Term",
    color: "#8EE8D8",
    meetings: [
      { label: "Regular Meeting", rule: "Last Tuesday in January" },
      { label: "Regular Meeting", rule: "First Saturday in March" },
    ]
  },
  {
    name: "Easter Term",
    color: "#8EE8D8",
    meetings: [
      { label: "Regular Meeting", rule: "Last Saturday in April" },
      { label: "Regular Meeting", rule: "Second Tuesday in June" },
    ]
  },
];
---
<BaseLayout title="Meetings" description="Meeting dates for Isaac Newton University Lodge No. 859.">

  <div class="page-header">
    <h1>Meetings</h1>
    <p>We meet six times per year across the three University of Cambridge terms</p>
  </div>

  <div class="content-section">

    <p class="intro">
      All meetings are held at <strong>Freemasons' Hall, Bateman Street, Cambridge</strong>.
      Meetings open at <strong>5pm</strong> and are followed by a Festive Board dinner.
    </p>

    <div class="terms-grid">
      {terms.map(term => (
        <div class="term-card">
          <div class="term-header">
            <h2>{term.name}</h2>
          </div>
          <ul class="meeting-list">
            {term.meetings.map(meeting => (
              <li class="meeting-item">
                <div class="meeting-rule">{meeting.rule}</div>
                <div class="meeting-label">{meeting.label}</div>
                {meeting.note && <p class="meeting-note">{meeting.note}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="dining-info">
      <h2>Dining</h2>
      <p>
        A Festive Board dinner follows each meeting. Members and their guests are warmly
        welcomed. To reserve a place at dinner, please contact the Secretary before the
        meeting. The first guest for INUL members dines free of charge; subsequent guests
        are charged at the full dining fee.
      </p>
      <p>
        Dining fee and menu details are circulated with each summons. Payments may be
        made via BACS to the lodge account.
      </p>
    </div>

    <div class="dress-info">
      <h2>Dress</h2>
      <p>
        <strong>Regular meetings:</strong> Lounge suit, white gloves.<br />
        <strong>Installation meeting:</strong> Dark lounge suit or morning dress.<br />
        Masonic regalia appropriate to rank should be worn.
      </p>
    </div>

  </div>

</BaseLayout>

<style>
  .intro {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--white);
    border-left: 4px solid var(--cambridge-blue);
    border-radius: 0 4px 4px 0;
  }

  .terms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .term-card {
    background: var(--white);
    border: 1px solid #e0ddd5;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .term-header {
    background: var(--navy);
    padding: 1rem 1.25rem;
  }

  .term-header h2 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .meeting-list { list-style: none; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

  .meeting-item { border-bottom: 1px solid #f0ede6; padding-bottom: 1rem; }
  .meeting-item:last-child { border-bottom: none; padding-bottom: 0; }

  .meeting-rule {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--navy);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .meeting-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meeting-note {
    font-size: 0.85rem;
    color: var(--cambridge-dark);
    margin-top: 0.3rem;
    font-style: italic;
  }

  .dining-info, .dress-info {
    background: var(--white);
    border: 1px solid #e0ddd5;
    border-radius: 6px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .dining-info h2, .dress-info h2 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--navy);
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .dining-info p, .dress-info p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
</style>
