---
import BaseLayout from '../layouts/BaseLayout.astro';

// Returns the nth occurrence of a weekday in a given month/year.
// weekday: 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
// n: 1=first, 2=second, -1=last
function getNthWeekday(year: number, month: number, weekday: number, n: number): Date {
  if (n > 0) {
    const date = new Date(year, month - 1, 1);
    let count = 0;
    while (date.getMonth() === month - 1) {
      if (date.getDay() === weekday) { count++; if (count === n) return new Date(date); }
      date.setDate(date.getDate() + 1);
    }
  } else {
    const date = new Date(year, month, 0); // last day of month
    while (date.getDay() !== weekday) date.setDate(date.getDate() - 1);
    return new Date(date);
  }
  throw new Error('Date not found');
}

function fmt(date: Date): string {
  return date.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

// 2025/2026 academic year dates
// weekdays: 2=Tuesday, 6=Saturday
const TUE = 2, SAT = 6;

const terms = [
  {
    name: "Michaelmas Term",
    year: "2025",
    meetings: [
      {
        label: "Installation Meeting",
        rule: "Last Tuesday in October",
        date: fmt(getNthWeekday(2025, 10, TUE, -1)),
        note: "The annual Installation of the Worshipful Master.",
      },
      {
        label: "Regular Meeting",
        rule: "First Saturday in December",
        date: fmt(getNthWeekday(2025, 12, SAT, 1)),
      },
    ],
  },
  {
    name: "Lent Term",
    year: "2026",
    meetings: [
      {
        label: "Regular Meeting",
        rule: "Last Tuesday in January",
        date: fmt(getNthWeekday(2026, 1, TUE, -1)),
      },
      {
        label: "Regular Meeting",
        rule: "First Saturday in March",
        date: fmt(getNthWeekday(2026, 3, SAT, 1)),
      },
    ],
  },
  {
    name: "Easter Term",
    year: "2026",
    meetings: [
      {
        label: "Regular Meeting",
        rule: "Last Saturday in April",
        date: fmt(getNthWeekday(2026, 4, SAT, -1)),
      },
      {
        label: "Regular Meeting",
        rule: "Second Tuesday in June",
        date: fmt(getNthWeekday(2026, 6, TUE, 2)),
      },
    ],
  },
];
---
<BaseLayout title="Meetings" description="Meeting dates for Isaac Newton University Lodge No. 859.">

  <div class="page-header">
    <h1>Meetings 2025 / 2026</h1>
    <p>We meet six times per year across the three University of Cambridge terms</p>
  </div>

  <div class="content-section">

    <p class="intro">
      All meetings are held at <strong>Freemasons' Hall, Bateman Street, Cambridge</strong>.
      Meetings open at <strong>5pm</strong> and are followed by a Festive Board dinner.
    </p>

    <div class="terms-grid">
      {terms.map(term => (
        <div class="term-card">
          <div class="term-header">
            <h2>{term.name}</h2>
          </div>
          <ul class="meeting-list">
            {term.meetings.map(meeting => (
              <li class="meeting-item">
                <div class="meeting-row">
                  <span class="meeting-rule">{meeting.rule}</span>
                  <span class="meeting-date">{meeting.date}</span>
                </div>
                <div class="meeting-label">{meeting.label}</div>
                {meeting.note && <p class="meeting-note">{meeting.note}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="dining-info">
      <h2>Dining</h2>
      <p>
        A Festive Board dinner follows each meeting. Members and their guests are warmly
        welcomed. To reserve a place at dinner, please contact the Secretary before the
        meeting. The first guest for INUL members dines free of charge; subsequent guests
        are charged at the full dining fee.
      </p>
      <p>
        Dining fee and menu details are circulated with each summons. Payments may be
        made via BACS to the lodge account.
      </p>
    </div>

    <div class="dress-info">
      <h2>Dress</h2>
      <p>
        <strong>Regular meetings:</strong> Lounge suit, white gloves.<br />
        <strong>Installation meeting:</strong> Dark lounge suit or morning dress.<br />
        Masonic regalia appropriate to rank should be worn.
      </p>
    </div>

  </div>

</BaseLayout>

<style>
  .intro {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--white);
    border-left: 4px solid var(--cambridge-blue);
    border-radius: 0 4px 4px 0;
  }

  .terms-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .term-card {
    background: var(--white);
    border: 1px solid #e0ddd5;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .term-header {
    background: var(--navy);
    padding: 1rem 1.25rem;
  }

  .term-header h2 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .meeting-list { list-style: none; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

  .meeting-item { border-bottom: 1px solid #f0ede6; padding-bottom: 1rem; }
  .meeting-item:last-child { border-bottom: none; padding-bottom: 0; }

  .meeting-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.2rem;
  }

  .meeting-rule {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--navy);
    font-weight: 600;
  }

  .meeting-date {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--cambridge-dark);
    font-weight: 700;
  }

  .meeting-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meeting-note {
    font-size: 0.85rem;
    color: var(--cambridge-dark);
    margin-top: 0.3rem;
    font-style: italic;
  }

  .dining-info, .dress-info {
    background: var(--white);
    border: 1px solid #e0ddd5;
    border-radius: 6px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .dining-info h2, .dress-info h2 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--navy);
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .dining-info p, .dress-info p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
</style>
