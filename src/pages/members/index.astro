---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Members Login" description="Members login for Isaac Newton University Lodge No. 859.">

  <div class="login-page">
    <div class="login-card">
      <img src="/inul-crest.jpg" alt="INUL Crest" class="login-crest" />
      <h1>Members Area</h1>
      <p class="login-sub">Isaac Newton University Lodge No. 859</p>

      <form id="login-form" class="login-form" novalidate>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Enter password" autocomplete="current-password" required />
        </div>
        <p class="error-msg" id="error-msg"></p>
        <button type="submit" class="login-btn">Enter</button>
      </form>
    </div>
  </div>

</BaseLayout>

<script>
  const MEMBERS_PASSWORD = 'INUL859';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg')!;

  // Already logged in? Redirect.
  if (sessionStorage.getItem('inul-member-auth') === 'true') {
    window.location.href = '/members/dashboard';
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const pw = (document.getElementById('password') as HTMLInputElement).value;
    if (pw === MEMBERS_PASSWORD) {
      sessionStorage.setItem('inul-member-auth', 'true');
      window.location.href = '/members/dashboard';
    } else {
      errorMsg.textContent = 'Incorrect password. Please try again.';
      (document.getElementById('password') as HTMLInputElement).value = '';
    }
  });
</script>

<style>
  .login-page {
    min-height: calc(100vh - 64px - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    background: var(--off-white);
  }

  .login-card {
    background: var(--white);
    border: 1px solid #e0ddd5;
    border-radius: 8px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .login-crest {
    width: 90px;
    height: auto;
    margin-bottom: 1.25rem;
  }

  .login-card h1 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--navy);
    letter-spacing: 0.06em;
    margin-bottom: 0.25rem;
  }

  .login-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .login-form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }

  .field label {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
  }

  .field input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid #c8c4ba;
    border-radius: 3px;
    width: 100%;
  }

  .field input:focus {
    outline: none;
    border-color: var(--cambridge-dark);
    box-shadow: 0 0 0 3px rgba(142,232,216,0.3);
  }

  .error-msg {
    color: #c0392b;
    font-size: 0.85rem;
    min-height: 1.2em;
    text-align: center;
  }

  .login-btn {
    padding: 0.8rem;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .login-btn:hover { background: var(--gold); color: var(--navy); }
</style>
